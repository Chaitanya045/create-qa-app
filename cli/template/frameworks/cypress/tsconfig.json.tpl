{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "cypress"],
    "noUncheckedIndexedAccess": true
  },
  "include": ["cypress.config.ts", "cypress/**/*.ts"]
}
