{
  "name": "create-qa-app",
  "version": "0.1.1",
  "description": "Scaffold type-safe automation testing projects",
  "type": "module",
  "bin": {
    "create-qa-app": "dist/index.js"
  },
  "files": [
    "dist",
    "cli/template"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Chaitanya045/create-qa-app"
  },
  "keywords": [
    "playwright",
    "testing",
    "scaffold",
    "qa",
    "e2e"
  ],
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "tsup",
    "dev": "bun run cli/src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "check": "bun run typecheck && bun run lint && bun run format:check"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@clack/prompts": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^25.2.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.8.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
